# === AI Providers ===
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for OpenAI provider.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# ANTHROPIC_API_KEY: Required for Anthropic/Claude provider.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# OLLAMA_URL: URL for local Ollama instance (default: http://localhost:11434)
OLLAMA_URL="http://localhost:11434"

# === Server ===
# APP_URL: The URL where the app is hosted.
APP_URL="http://localhost:3000"

# VITE_SERVER_URL: Required for Android/Capacitor APKs so the bundled client can
# reach the Express/WebSocket server from the phone. Use your computer LAN IP.
# Example: VITE_SERVER_URL="http://192.168.1.10:3000"
VITE_SERVER_URL=""

# PORT: Server port (default: 3000)
PORT=3000

# APP_ACCESS_TOKEN: Optional shared token for /api/providers and WebSocket access.
# If set, also set VITE_APP_ACCESS_TOKEN to the same value for the bundled client.
APP_ACCESS_TOKEN=""
VITE_APP_ACCESS_TOKEN=""

# AI_PROVIDER_TIMEOUT_MS: Per-provider timeout before trying fallback (default: 15000)
AI_PROVIDER_TIMEOUT_MS=15000

# TRUST_PROXY: Set to true or a hop count (for example 1) only behind a trusted reverse proxy.
TRUST_PROXY=""
