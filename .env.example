# === AI Providers ===
# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for OpenAI provider.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# ANTHROPIC_API_KEY: Required for Anthropic/Claude provider.
ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# OLLAMA_URL: URL for local Ollama instance (default: http://localhost:11434)
OLLAMA_URL="http://localhost:11434"

# === Server ===
# APP_URL: The URL where the app is hosted.
APP_URL="http://localhost:3000"

# PORT: Server port (default: 3000)
PORT=3000
